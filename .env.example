# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════════════════════

# Supabase (or any Postgres) connection string.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Leave blank to run in --no-db (local file output only) mode.
DATABASE_URL=

# ════════════════════════════════════════════════════════════════════════════
# LLM EXTRACTION  (optional — falls back to rule-based regex if not set)
# ════════════════════════════════════════════════════════════════════════════

# Groq API key — enables llama-3.1-8b-instant for structured field extraction.
# Get one free at https://console.groq.com
# LLAMA_API_KEY is accepted as an alias for backwards compatibility.
GROQ_API_KEY=
# LLAMA_API_KEY=

# Optional: route LLM extraction through your hosted server endpoint instead of direct Groq calls.
# Useful when workers should only call your API service.
# Example: GROQ_LLM_ENDPOINT_URL=https://your-server-domain/api/v1/llm/extract
# GROQ_LLM_ENDPOINT_URL=
# GROQ_LLM_ENDPOINT_TIMEOUT_S=60

# Apache County Assessor credentials for the authenticated Arizona scraper.
# The linked sale search and account pages require a registered user session.
APACHE_ASSESSOR_USERNAME=
APACHE_ASSESSOR_PASSWORD=
# APACHE_ASSESSOR_BASE_URL=https://eagleassessor.co.apache.az.us
# APACHE_ASSESSOR_TIMEOUT_S=30
# APACHE_ASSESSOR_BEGIN_DATE_FIELD=fromDate
# APACHE_ASSESSOR_END_DATE_FIELD=toDate

# ════════════════════════════════════════════════════════════════════════════
# API SERVER  (optional — sensible defaults shown)
# ════════════════════════════════════════════════════════════════════════════

# Protect POST /api/v1/scrape and other mutating endpoints with a bearer token.
# Recommended in production. Leave blank to allow unauthenticated access (local dev only).
API_TOKEN=

# Server bind address for uvicorn / gunicorn.
# HOST and PORT are used by run_server.sh; BIND overrides both for gunicorn directly.
# HOST=0.0.0.0
# PORT=8080
# BIND=0.0.0.0:8080

# Deployment timezone. Use Arizona / Phoenix time for date boundaries and cron logs.
# TZ=America/Phoenix

# CORS allowed origins (comma-separated). Defaults to * (allow all).
# Tighten this in production to your frontend domain(s).
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ════════════════════════════════════════════════════════════════════════════
# SCRAPER BEHAVIOUR  (optional — sensible defaults shown)
# ════════════════════════════════════════════════════════════════════════════

# How to handle downloaded PDFs:
#   memory  — OCR from in-memory bytes, nothing written to disk (default in production)
#   save    — write PDFs to downloads/documents/<recording_number>.pdf
# PDF_MODE=memory

# Enable proxy rotation for HTTP requests. Set to true only if your proxy list contains US IPs.
# USE_PROXY=false

# Path to a newline-delimited proxy list (host:port or host:port:user:pass).
# Only used when --use-proxy flag is passed to the scraper.
# PROXY_LIST_PATH=proxy_list.txt

# Custom path for the "latest" CSV export (served via GET /csv/latest).
# CSV_PATH=output/new_records_latest.csv

# ════════════════════════════════════════════════════════════════════════════
# GUNICORN / LOGGING  (optional — sensible defaults shown)
# ════════════════════════════════════════════════════════════════════════════

# Number of threads per Gunicorn worker (default: 4).
# GUNICORN_THREADS=4

# Gunicorn worker timeout in seconds. Scrape jobs can run up to ~1 hour.
# GUNICORN_TIMEOUT=3600

# Log level for the scraper and API server: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════════════════════
# OCR  (optional — only needed if Tesseract's temp dir causes issues on macOS)
# ════════════════════════════════════════════════════════════════════════════

# Force both pdf2image and pytesseract to use the same real temp path.
# Fixes the /tmp → /private/tmp symlink mismatch on macOS.
# TMPDIR=/private/tmp
