# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────
# Supabase Postgres connection string
# Format: postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres
DATABASE_URL=

# ── Optional ──────────────────────────────────────────────────────────────
# Protect the API endpoints with a bearer token (recommended in production)
API_TOKEN=

# Server bind settings (defaults: 0.0.0.0 and 8080)
# HOST=0.0.0.0
# PORT=8080

# CORS allowed origins (comma-separated, default: * which allows all)
# CORS_ORIGINS=https://yourdomain.com
