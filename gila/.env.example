# Gila County Scraper — Environment Variables
# Copy this file to .env and fill in your values.

# Required for Groq LLM extraction (address + principal from OCR text)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override Groq model (default: llama-3.3-70b-versatile)
# GILA_GROQ_MODEL=llama-3.3-70b-versatile

# Optional: override date range for cron runs (MM/DD/YYYY)
# GILA_START_DATE=2/13/2026
# GILA_END_DATE=3/13/2026
